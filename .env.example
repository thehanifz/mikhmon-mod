# ─────────────────────────────────────────────────────────
# MIKHMON V3 — Environment Configuration Template
# ─────────────────────────────────────────────────────────
# CARA PAKAI:
#   1. Copy file ini: cp .env.example .env
#   2. Isi nilainya
#   3. JANGAN commit .env ke git!
# ─────────────────────────────────────────────────────────

# Secret key untuk enkripsi AES-256-GCM
# Generate: openssl rand -hex 32
MIKHMON_SECRET=ganti_dengan_random_string_minimal_32_karakter_disini

# Environment (production / development)
MIKHMON_ENV=production

# Session cookie name
MIKHMON_SESSION_NAME=mkhm_sess
